        let relatorio = "📊 *RELATÓRIO DIÁRIO DE INFRAÇÕES*\n\n";
        let infratores = 0;

        for (const [chave, dados] of Object.entries(dadosDoDia)) {
            if (dados.alertouPostExcedido || dados.alertouMidiaExcedida) {
                const [idGrupo, numeroUsuario] = chave.split("_");
                const linkContato = numeroUsuario.length >= 14 ? '*Oculto pelo WhatsApp*' : `[${numeroUsuario}](https://wa.me/${numeroUsuario})`;

