// ZERA CONTADORES E GERA RELATÓRIO
// =========================================
setInterval(async () => {
    const agora = new Date();
    const brasil = new Date(agora.toLocaleString("en-US", { timeZone:"America/Sao_Paulo" }));

    if (brasil.getHours() === 0 && brasil.getMinutes() === 0) {
